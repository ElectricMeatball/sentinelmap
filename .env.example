# ─── SentinelMap Environment Variables ───────────────────────────────────────

# Node environment
NODE_ENV=production

# Server port (backend API)
PORT=3000

# Frontend dev port (Vite)
VITE_PORT=5000

# PostgreSQL (optional — app falls back to in-memory if not set)
# DATABASE_URL=postgresql://sentinelmap:changeme@db:5432/sentinelmap

# Session secret (change this in production)
SESSION_SECRET=change-this-to-a-long-random-string-in-production

# Feed refresh interval in milliseconds (default 3 hours)
FEED_CACHE_TTL_MS=10800000

# Optional: AlienVault OTX API key (for future OTX feed integration)
# OTX_API_KEY=

# Optional: AbuseIPDB API key (for future AbuseIPDB enrichment)
# ABUSEIPDB_API_KEY=

# Optional: GreyNoise API key (for future GreyNoise integration)
# GREYNOISE_API_KEY=

# Optional: Shodan API key (for future Shodan enrichment)
# SHODAN_API_KEY=

# CORS origins (comma-separated, for production)
# CORS_ORIGINS=https://yourdomain.com
