# =============================================
# AEROGUARD THREAT MAP — Environment Variables
# =============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Server ---
# Port the app listens on (default: 5000)
PORT=5000

# Required: secret used to sign session cookies
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_a_long_random_string

# --- Database (Optional) ---
# PostgreSQL connection URL
# If not set, the app uses in-memory storage (data resets on restart)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# DATABASE_URL=postgresql://aeroguard:password@localhost:5432/aeroguard

# --- Node ---
NODE_ENV=production
